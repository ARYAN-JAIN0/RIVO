## Database Configuration
# Default: SQLite (safe local default)
# DATABASE_URL=sqlite:///./rivo.db
# Optional: require DB connectivity at startup (defaults True in production, False otherwise)
# DB_CONNECTIVITY_REQUIRED=false
# PostgreSQL example (set real values in local `.env` only):
# DATABASE_URL=postgresql+psycopg2://rivo_user:change_me@localhost:5432/rivo

## Environment
# ENV=development
# DEBUG=True

## API
# API_HOST=0.0.0.0
# API_PORT=8000
# API_PREFIX=/api/v1

## Auth
# JWT_SECRET=change_me_jwt_secret
# JWT_ACCESS_TTL_MINUTES=15
# JWT_REFRESH_TTL_DAYS=14
# JWT_PERMISSIONS_VERSION=1

## Queue / Redis
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

## LLM
# Backward-compatible base URL (used to derive endpoints if split URLs are not set):
# OLLAMA_URL=http://localhost:11434
# Explicit split endpoints (recommended):
# OLLAMA_GENERATE_URL=http://localhost:11434/api/generate
# OLLAMA_EMBEDDING_URL=http://localhost:11434/api/embeddings
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# RAG_USE_REAL_EMBEDDINGS=true
# RAG_EMBEDDING_DIMS=768
# LLM_TIMEOUT_SECONDS=90
# LLM_MAX_RETRIES=2
# LLM_MIN_INTERVAL_SECONDS=0.25

## Email (SDR path)
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587
# GMAIL_SMTP_USER=
# GMAIL_SMTP_APP_PASSWORD=
# GMAIL_FROM_EMAIL=
# SMTP_SANDBOX_MODE=true
# TRACKING_BASE_URL=http://localhost:8000

## Rate limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_DEFAULT=100/minute
# RATE_LIMIT_TRACKING=1000/minute
# RATE_LIMIT_AUTH=10/minute
# RATE_LIMIT_ADMIN=30/minute

## Logging
# LOG_LEVEL=INFO
# LOG_FILE=rivo.log
